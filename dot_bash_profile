# For [nnn file manager](https://github.com/jarun/nnn)
cnn ()
{
    # Block nesting of nnn in subshells
    [ "${NNNLVL:-0}" -eq 0 ] || {
        echo "nnn is already running"
        return
    }

    # The behaviour is set to cd on quit (nnn checks if NNN_TMPFILE is set)
    # If NNN_TMPFILE is set to a custom path, it must be exported for nnn to
    # see. To cd on quit only on ^G, remove the "export" and make sure not to
    # use a custom path, i.e. set NNN_TMPFILE *exactly* as follows:
    #      NNN_TMPFILE="${XDG_CONFIG_HOME:-$HOME/.config}/nnn/.lastd"
    export NNN_TMPFILE="${XDG_CONFIG_HOME:-$HOME/.config}/nnn/.lastd"

    # Unmask ^Q (, ^V etc.) (if required, see `stty -a`) to Quit nnn
    # stty start undef
    # stty stop undef
    # stty lwrap undef
    # stty lnext undef

    # The command builtin allows one to alias nnn to n, if desired, without
    # making an infinitely recursive alias
    command nnn "$@"

    [ ! -f "$NNN_TMPFILE" ] || {
        . "$NNN_TMPFILE"
        rm -f -- "$NNN_TMPFILE" > /dev/null
    }
}

# Bootstrap a new skill from the skills-framework template
bootstrap_skill() {
    local RED='\033[0;31m'
    local GREEN='\033[0;32m'
    local YELLOW='\033[1;33m'
    local BLUE='\033[0;34m'
    local NC='\033[0m'

    echo -e "${BLUE}🎯 Skill Framework Bootstrap${NC}"
    echo ""

    while true; do
        printf "Enter your skill name (kebab-case, e.g., my-awesome-skill): "
        read SKILL_NAME || return 1

        if [[ -z "$SKILL_NAME" ]]; then
            echo "Cancelled."
            return 1
        fi

        if [[ "$SKILL_NAME" =~ ^[a-z][a-z0-9]*(-[a-z0-9]+)*$ ]]; then
            break
        else
            echo -e "${RED}❌ Invalid skill name${NC}"
            echo "Skill name must be:"
            echo "  • Lowercase letters and numbers only"
            echo "  • Use hyphens to separate words (e.g., my-awesome-skill)"
            echo "  • Start with a letter"
            echo "  • No consecutive hyphens"
            echo ""
        fi
    done

    echo ""
    echo "📥 Cloning skills-framework repository..."
    git clone https://github.com/kucukkanat/skills-framework "$SKILL_NAME"

    if [ ! -d "$SKILL_NAME" ]; then
        echo -e "${RED}❌ Failed to clone repository${NC}"
        return 1
    fi

    cd "$SKILL_NAME"

    echo "🗑️  Removing git remote origin..."
    git remote remove origin

    echo "📝 Updating skill name in files..."

    sed -i '' 's/"name": "skill-framework-bootstrap"/"name": "'"$SKILL_NAME"'"/' package.json

    sed -i '' 's/name: example-skill/name: '"$SKILL_NAME"'/' src/SKILL.md
    sed -i '' 's|/example-skill|/'"$SKILL_NAME"'|g' src/SKILL.md

    sed -i '' 's/example-skill/'"$SKILL_NAME"'/g' src/scripts/example.ts

    echo -e "${GREEN}✅ Skill bootstrapped successfully!${NC}"
    echo ""
    echo -e "${BLUE}📁 Location:${NC} $(pwd)"
    echo ""
    echo -e "${YELLOW}📝 Next steps:${NC}"
    echo "  1. cd $SKILL_NAME"
    echo "  2. Edit src/SKILL.md with your skill's description"
    echo "  3. Write scripts in src/scripts/"
    echo "  4. bun build.ts && ./install.sh"
    echo ""
    echo -e "${BLUE}🚀 Happy coding!${NC}"
}

